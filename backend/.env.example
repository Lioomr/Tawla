DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
TABLE_SESSION_DURATION_MINUTES=60
POSTGRES_DB=tawlax
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-secure-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1
JWT_ROTATE_REFRESH_TOKENS=true
JWT_BLACKLIST_AFTER_ROTATION=true
JWT_UPDATE_LAST_LOGIN=true
RATE_LIMIT_STAFF_LOGIN=5/minute
RATE_LIMIT_ORDER_CREATE=10/minute
RATE_LIMIT_PAYMENT_CREATE=5/minute
