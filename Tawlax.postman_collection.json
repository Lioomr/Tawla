          "name": "Start Session - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('session_token', response.session_token);",
                  "",
                  "pm.test('Session token returned', function () {",
                  "    pm.expect(response.session_token).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('Expires at returned', function () {",
                  "    pm.expect(response.expires_at).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_token\": \"{{table_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/table/session/start/",
