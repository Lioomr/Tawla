                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "table",
                "session",
                "start",
                ""
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Menu",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "const drinks = response.categories.find(category => category.name === 'Drinks');",
                  "const meals = response.categories.find(category => category.name === 'Meals');",
                  "if (drinks && drinks.items.length > 0) {",
                  "    pm.collectionVariables.set('cola_item_id', String(drinks.items[0].id));",
                  "}",
                  "if (meals && meals.items.length > 0) {",
                  "    pm.collectionVariables.set('burger_item_id', String(meals.items[0].id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Session-Token",
                "value": "{{session_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/menu/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "menu",
                ""
              ]
            }
          },
          "response": []
        },
